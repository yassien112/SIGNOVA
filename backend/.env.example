# ─────────────────────────────────────────────
# SIGNOVA Backend — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# Server
PORT=5000

# ─── Database (Neon PostgreSQL) ───────────────
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
DIRECT_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── Auth ─────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string
AUTH_ACCESS_TOKEN_TTL=15m
AUTH_REFRESH_TOKEN_TTL_MS=2592000000
AUTH_BCRYPT_ROUNDS=10

# ─── OpenAI (Whisper / Speech-to-Text) ────────
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_SPEECH_MODEL=gpt-4o-mini-transcribe
OPENAI_SPEECH_TIMEOUT_MS=20000
OPENAI_SPEECH_MAX_FILE_BYTES=26214400
OPENAI_SPEECH_PROMPT=Transcribe short chat messages accurately. Preserve Arabic and English words, names, and punctuation naturally.

# ─── File Storage ─────────────────────────────
# Provider: backblaze | r2 | supabase
STORAGE_PROVIDER=backblaze
STORAGE_BASE_URL=https://f000.backblazeb2.com/file/signova-signs
STORAGE_BUCKET=signova-signs
STORAGE_KEY_ID=
STORAGE_APP_KEY=
STORAGE_ENDPOINT=s3.us-west-004.backblazeb2.com

# ─── Notifications ────────────────────────────
NOTIFICATIONS_ENABLED=true
NOTIFICATIONS_MAX_PER_USER=200

# ─── Sign Language Engine ──────────────────────
SL_STABILIZATION_WINDOW_MS=750
SL_COMMIT_HOLD_MS=140
SL_DUPLICATE_COOLDOWN_MS=850
SL_PHRASE_PAUSE_MS=1600
SL_MIN_CONFIDENCE=0.55
SL_MIN_SUPPORT=0.5
SL_MIN_OCCURRENCES=3
SL_MAX_BATCH_SIZE=24
SL_SESSION_TTL_MS=600000
