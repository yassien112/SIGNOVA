# Listen on all interfaces so phones on the same Wi‑Fi can reach http://<YOUR-LAN-IP>:PORT
PORT=5000
JWT_SECRET=signova-super-secret-key-2026

# Required for Voice to Write (POST /api/speech-to-text). Get a key at https://platform.openai.com/api-keys
# Also accepted: OPENAI_KEY (alias). No quotes; no spaces around =.
OPENAI_API_KEY=
OPENAI_SPEECH_MODEL=gpt-4o-mini-transcribe
OPENAI_SPEECH_TIMEOUT_MS=20000
OPENAI_SPEECH_MAX_FILE_BYTES=26214400
OPENAI_SPEECH_PROMPT=Transcribe short chat messages accurately. Preserve Arabic and English words, names, and punctuation naturally.
