# --- Local PC only (default) ---
# Leave VITE_BACKEND_URL unset so /api is proxied by Vite. On your phone, open the "Network"
# URL from the Vite terminal (http://<LAN-IP>:3000), not localhost.

# Wrong for phone testing (points API at the phone itself):
# VITE_BACKEND_URL=http://localhost:5000

# If the API runs on another machine/port, use the reachable URL, e.g.:
# VITE_BACKEND_URL=http://192.168.1.19:5000

# Dev proxy target on your PC (where Node backend listens). Default is fine:
# VITE_DEV_PROXY_TARGET=http://localhost:5000

# --- Microphone on mobile (recommended) ---
# Use the dev:lan script instead of setting this manually; it enables HTTPS + self-signed cert.
# VITE_DEV_HTTPS=1
