# ============================================================
# SIGNOVA – Frontend environment variables
# Copy this file to .env and fill in the values.
# ============================================================

# ------------------------------------------------------------------
# VITE_BACKEND_URL
#   The full URL of the backend server.
#
#   | Scenario                  | Value                                    |
#   |---------------------------|------------------------------------------|
#   | Local dev (same PC)       | leave empty or delete the line           |
#   | Local dev (phone / LAN)   | http://192.168.1.X:5000                  |
#   | Production (Vercel)       | https://your-backend.railway.app         |
#
#   When empty, Vite's dev proxy forwards /api and /socket.io
#   to http://localhost:5000 automatically.
# ------------------------------------------------------------------
# VITE_BACKEND_URL=

# ------------------------------------------------------------------
# VITE_DEV_PROXY_TARGET  (optional, dev only)
#   Override the proxy target if your backend runs on a different
#   port. Defaults to VITE_BACKEND_URL or http://localhost:5000.
# ------------------------------------------------------------------
# VITE_DEV_PROXY_TARGET=http://localhost:5000

# ------------------------------------------------------------------
# VITE_DEV_HTTPS  (optional, dev only)
#   Set to 1 to start Vite with a self-signed HTTPS certificate.
#   Required for microphone access when testing on mobile over LAN.
# ------------------------------------------------------------------
# VITE_DEV_HTTPS=1
